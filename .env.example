# Copy this file to .env.local and point the React app to your backend API.
VITE_API_BASE_URL=https://api.example.com
VITE_API_TIMEOUT_MS=10000

# Endpoints can be absolute URLs or paths under VITE_API_BASE_URL.
VITE_SEVAS_ENDPOINT=/sevas
VITE_BENEFITS_ENDPOINT=/benefits
VITE_TESTIMONIALS_ENDPOINT=/testimonials
VITE_FAQS_ENDPOINT=/faqs
VITE_BOOKING_ENDPOINT=/bookings
